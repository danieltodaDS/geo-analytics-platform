# Makefile de provisionamento GCP — fase 4c
# Arquivo local, não versionado (.gitignore).
# Execute os targets em ordem ou individualmente conforme necessário.
# Pré-requisito: ADC autenticada (make auth no Makefile principal).

PROJECT=data-pipeline-lab-497514
BUCKET=geo-analytics-platform-raw
PROJECT_NUMBER=549617161512
REPO=danieltodaDS/geo-analytics-platform

.PHONY: passo-0 passo-2a passo-2b passo-2c passo-2d passo-3 passo-4 passo-5a passo-10a provision

# Passo 0 — Criar datasets BigQuery (pré-requisito de passo-2d e dbt)
passo-0:
	gcloud config set project $(PROJECT)
	-bq mk --dataset --location=US $(PROJECT):raw
	-bq mk --dataset --location=US $(PROJECT):staging
	-bq mk --dataset --location=US $(PROJECT):intermediate
	-bq mk --dataset --location=US $(PROJECT):marts
	bq ls --project_id=$(PROJECT)

# Passo 2a — Criar bucket GCS
passo-2a:
	gcloud storage buckets create gs://$(BUCKET) \
	  --location=US \
	  --uniform-bucket-level-access

# Passo 2b — Criar WIF pool e provider OIDC
passo-2b:
	gcloud iam workload-identity-pools create github-actions \
	  --location=global \
	  --project=$(PROJECT) \
	  --display-name="GitHub Actions"
	gcloud iam workload-identity-pools providers create-oidc github \
	  --location=global \
	  --workload-identity-pool=github-actions \
	  --project=$(PROJECT) \
	  --issuer-uri="https://token.actions.githubusercontent.com" \
	  --attribute-mapping="google.subject=assertion.sub,attribute.repository=assertion.repository" \
	  --attribute-condition="assertion.repository=='$(REPO)'"

# Passo 2c — Criar SA de ingestão e vincular ao WIF
passo-2c:
	gcloud iam service-accounts create github-actions \
	  --project=$(PROJECT) \
	  --display-name="GitHub Actions"
	gcloud iam service-accounts add-iam-policy-binding \
	  github-actions@$(PROJECT).iam.gserviceaccount.com \
	  --project=$(PROJECT) \
	  --role="roles/iam.workloadIdentityUser" \
	  --member="principalSet://iam.googleapis.com/projects/$(PROJECT_NUMBER)/locations/global/workloadIdentityPools/github-actions/attribute.repository/$(REPO)"

# Passo 2d — IAM da SA de ingestão (GCS + BigQuery)
passo-2d:
	gcloud storage buckets add-iam-policy-binding gs://$(BUCKET) \
	  --role=roles/storage.objectUser \
	  --member=serviceAccount:github-actions@$(PROJECT).iam.gserviceaccount.com
	for ds in raw staging intermediate marts; do \
	  bq add-iam-policy-binding \
	    --dataset=$(PROJECT):$${ds} \
	    --role=roles/bigquery.dataEditor \
	    --member=serviceAccount:github-actions@$(PROJECT).iam.gserviceaccount.com; \
	done
	gcloud projects add-iam-policy-binding $(PROJECT) \
	  --role=roles/bigquery.jobUser \
	  --member=serviceAccount:github-actions@$(PROJECT).iam.gserviceaccount.com

# Passo 3 — Upload Olist → GCS (one-time, Parquets locais)
passo-3:
	gsutil -m cp -r \
	  data/raw/olist_customers \
	  data/raw/olist_orders \
	  data/raw/olist_order_items \
	  data/raw/olist_order_payments \
	  data/raw/olist_order_reviews \
	  data/raw/olist_geolocation \
	  data/raw/olist_products \
	  data/raw/olist_sellers \
	  gs://$(BUCKET)/raw/
	@echo "=== Verificação ==="
	gsutil ls gs://$(BUCKET)/raw/olist_orders/

# Passo 4 — Criar External Tables no dataset raw
passo-4:
	bash infra/setup_external_tables.sh

# Passo 5a — Drop dataset landing (confirmar External Tables OK antes)
passo-5a:
	@echo "Verificando volume via External Table antes de dropar landing..."
	bq query --nouse_legacy_sql \
	  'SELECT COUNT(*) as n FROM `$(PROJECT).raw.olist_orders`'
	@read -p "Volume correto (99441)? Digite 'sim' para continuar: " confirm; \
	if [ "$$confirm" = "sim" ]; then \
	  bq rm -r -f $(PROJECT):landing; \
	  echo "Dataset landing removido."; \
	else \
	  echo "Cancelado."; \
	fi

# Passo 10a — Criar SA streamlit-reader (somente leitura em marts)
passo-10a:
	gcloud iam service-accounts create streamlit-reader \
	  --project=$(PROJECT) \
	  --display-name="Streamlit Reader"
	bq add-iam-policy-binding \
	  --dataset=$(PROJECT):marts \
	  --role=roles/bigquery.dataViewer \
	  --member=serviceAccount:streamlit-reader@$(PROJECT).iam.gserviceaccount.com
	gcloud projects add-iam-policy-binding $(PROJECT) \
	  --role=roles/bigquery.jobUser \
	  --member=serviceAccount:streamlit-reader@$(PROJECT).iam.gserviceaccount.com
	@echo "Gerando chave JSON..."
	gcloud iam service-accounts keys create streamlit-key.json \
	  --iam-account=streamlit-reader@$(PROJECT).iam.gserviceaccount.com
	@echo ""
	@echo "=== COPIE O CONTEÚDO ABAIXO PARA O PAINEL DO STREAMLIT COMMUNITY CLOUD ==="
	@echo "    Secrets → gcp_service_account (colar como TOML)"
	@echo "==============================================================================="
	@cat streamlit-key.json
	@echo "==============================================================================="
	@rm streamlit-key.json
	@echo "Chave deletada localmente."
	@echo ""
	@echo ""
	@echo "=== SECRET ADICIONAL NO STREAMLIT COMMUNITY CLOUD ==="
	@echo "    Adicionar ao bloco de secrets (TOML):"
	@echo "    gcp_dataset_marts = \"marts\""
	@echo ""
	@echo "    (GCP_PROJECT é extraído automaticamente do project_id do service account)"

# Sequência completa de provisionamento (exceto passo-5a e passo-10a — requerem verificação manual)
provision: passo-0 passo-2a passo-2b passo-2c passo-2d passo-3 passo-4
	@echo ""
	@echo "=== Provisionamento concluído ==="
	@echo "Próximos passos manuais:"
	@echo "  make -f infra/Makefile.gcp passo-5a   (drop landing, após verificar volumes)"
	@echo "  make -f infra/Makefile.gcp passo-10a  (SA Streamlit, quando for ao ar)"
